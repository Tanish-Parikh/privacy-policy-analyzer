{
  "manifest_version": 3,
  "name": "Privacy Policy Analysis",
  "version": "8.1",
  "description": "Single-screen UI privacy policy analyzer (Centered Gauge Fix).",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "logo.png"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ]
    }
  ]
}